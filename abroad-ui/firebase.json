{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "function": "geoBlock"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" install --no-audit --no-fund",
      "cp \"$RESOURCE_DIR/../dist/index.html\" \"$RESOURCE_DIR/index.html\""
    ]
  }
}
